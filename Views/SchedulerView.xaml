<UserControl x:Class="SwiftClean.Views.SchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SwiftClean.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             d:DesignWidth="600" d:DesignHeight="640"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <!-- Frequency chip: accent when its bound flag is true -->
        <Style x:Key="FreqChip" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7" Padding="8" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                            <ContentPresenter HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
        <!-- Auto-clean toggle -->
        <Border Style="{StaticResource Panel}" Padding="16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding [sch.autoClean], Source={StaticResource Loc}}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                    <TextBlock Text="{Binding [sch.autoCleanSub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <ToggleButton Style="{StaticResource PillToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                              IsChecked="{Binding SchedulerEnabled, Mode=TwoWay}" />
            </Grid>
        </Border>

        <!-- Frequency -->
        <Border Style="{StaticResource Panel}" Padding="16" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding [sch.frequency], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Cursor="Hand" Command="{Binding FreqCommand}" CommandParameter="daily" Margin="0,0,3,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Padding="8" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                                    <TextBlock x:Name="T" Text="{Binding [sch.daily], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextFaintBrush}" HorizontalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFreqDaily}" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="T" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Cursor="Hand" Command="{Binding FreqCommand}" CommandParameter="weekly" Margin="3,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Padding="8" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                                    <TextBlock x:Name="T" Text="{Binding [sch.weekly], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextFaintBrush}" HorizontalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFreqWeekly}" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="T" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Cursor="Hand" Command="{Binding FreqCommand}" CommandParameter="monthly" Margin="3,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Padding="8" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                                    <TextBlock x:Name="T" Text="{Binding [sch.monthly], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextFaintBrush}" HorizontalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFreqMonthly}" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="T" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Time -->
        <Border Style="{StaticResource Panel}" Padding="16" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding [sch.time], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5"
                            CornerRadius="6" Padding="16,8">
                        <TextBox Text="{Binding ScheduleTimeText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 FontSize="16" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}"
                                 Background="Transparent" BorderThickness="0" CaretBrush="{StaticResource AccentBrush}"
                                 SelectionBrush="{StaticResource AccentBrush}" FocusVisualStyle="{x:Null}"
                                 MinWidth="52" TextAlignment="Center" MaxLength="5"
                                 VerticalContentAlignment="Center" Padding="0" />
                    </Border>

                    <!-- AM/PM toggle — visible in English only -->
                    <StackPanel Orientation="Horizontal" Margin="6,0,0,0"
                                Visibility="{Binding IsEnglish, Source={StaticResource Loc}, Converter={StaticResource BoolToVis}}">
                        <Button Command="{Binding ToggleAmCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" CornerRadius="5,0,0,5" Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5">
                                        <TextBlock x:Name="T" Text="AM" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource TextFaintBrush}" Margin="10,6" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource RowHoverBrush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding DataContext.SchedTimeIsAm, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                            <Setter TargetName="T" Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding TogglePmCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" CornerRadius="0,5,5,0" Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0.5,0.5,0.5">
                                        <TextBlock x:Name="T" Text="PM" FontSize="12" FontWeight="Medium"
                                                   Foreground="{StaticResource TextFaintBrush}" Margin="10,6" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource RowHoverBrush}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding DataContext.SchedTimeIsPm, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                            <Setter TargetName="T" Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Time steppers (±30 min) -->
                    <StackPanel Margin="6,0,0,0" VerticalAlignment="Center">
                        <Button Command="{Binding TimeUpCommand}" Cursor="Hand" ToolTip="+30 мин">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Width="26" Height="17" CornerRadius="5,5,0,0" Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5">
                                        <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource RowHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding TimeDownCommand}" Cursor="Hand" ToolTip="−30 мин">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Width="26" Height="17" CornerRadius="0,0,5,5" Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5,0,0.5,0.5">
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource RowHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding [sch.timeNote], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource SectionLabelBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- What to clean -->
        <Border Style="{StaticResource Panel}" Padding="16" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding [sch.what], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" Margin="0,0,0,14" />
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="{Binding [sch.temp], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                    <ToggleButton Style="{StaticResource BoxCheck}" HorizontalAlignment="Right" IsChecked="{Binding SchedCleanTemp, Mode=TwoWay}" />
                </Grid>
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="{Binding [sch.recycle], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                    <ToggleButton Style="{StaticResource BoxCheck}" HorizontalAlignment="Right" IsChecked="{Binding SchedCleanRecycle, Mode=TwoWay}" />
                </Grid>
                <Grid>
                    <TextBlock Text="{Binding [sch.cache], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                    <ToggleButton Style="{StaticResource BoxCheck}" HorizontalAlignment="Right" IsChecked="{Binding SchedCleanCache, Mode=TwoWay}" />
                </Grid>
            </StackPanel>
        </Border>

        <Button Style="{StaticResource AccentButton}" Padding="10" Margin="0,12,0,0"
                Content="{Binding [sch.save], Source={StaticResource Loc}}" Command="{Binding SaveScheduleCommand}" />
    </StackPanel>
</UserControl>
