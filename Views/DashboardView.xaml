<UserControl x:Class="SwiftClean.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SwiftClean.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             d:DesignWidth="900" d:DesignHeight="560"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="StatRed" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasScanData}" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource SectionLabelBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatAmber" TargetType="TextBlock" BasedOn="{StaticResource StatRed}">
            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- ===== Left column ===== -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Stat cards 2x2 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Panel}" Padding="14" Margin="0,0,5,5">
                    <StackPanel>
                        <TextBlock Text="{Binding [dash.junk], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" Foreground="{StaticResource StatLabelBrush}" />
                        <TextBlock Text="{Binding DashJunk}" Style="{StaticResource StatRed}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding [dash.junkSub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Panel}" Padding="14" Margin="5,0,0,5">
                    <StackPanel>
                        <TextBlock Text="{Binding [dash.registry], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                        <TextBlock Text="{Binding DashReg}" Style="{StaticResource StatAmber}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding [dash.regSub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Panel}" Padding="14" Margin="0,5,5,0">
                    <StackPanel>
                        <TextBlock Text="{Binding [dash.startup], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                        <TextBlock Text="{Binding DashStartupDelay}" Style="{StaticResource StatAmber}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding [dash.startupSub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Panel}" Padding="14" Margin="5,5,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding [dash.free], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                        <TextBlock Text="{Binding DiskFreeText}" FontSize="22" FontWeight="Medium" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding DiskFreeOfLine}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Found junk -->
            <Border Grid.Row="1" Style="{StaticResource Panel}" Margin="0,7,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="14,12">
                        <Grid>
                            <TextBlock Text="{Binding [dash.found], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" />
                            <TextBlock Text="{Binding SelectedText}"
                                       HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource TextFaintBrush}"
                                       Visibility="{Binding HasScanData, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding NoScanData, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                   Foreground="{StaticResource BorderLightBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding [dash.empty1], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource StatLabelBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding [dash.empty2], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource StatLabelBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- List + footer -->
                    <Grid Grid.Row="1" Visibility="{Binding HasScanData, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CleanItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,0.5">
                                            <StackPanel>
                                                <Grid Margin="14,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="7"
                                                            Background="{Binding IconBgHex, Converter={StaticResource StringToBrush}}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   Foreground="{Binding IconColorHex, Converter={StaticResource StringToBrush}}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Desc}" FontSize="11" Foreground="{StaticResource StatLabelBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding DisplaySize}" FontSize="12"
                                                               Foreground="{StaticResource StatLabelBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                    <ToggleButton Grid.Column="3" Style="{StaticResource Chevron}" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                                  Visibility="{Binding HasDetails, Converter={StaticResource BoolToVis}}" />
                                                    <ToggleButton Grid.Column="4" Style="{StaticResource BoxCheck}"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                                </Grid>
                                                <Border Style="{StaticResource FilePreview}">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                        <StackPanel>
                                                            <!-- Browsers (Browser Cache only) -->
                                                            <StackPanel Visibility="{Binding HasBrowsers, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="{Binding [cookies.hint], Source={StaticResource Loc}}" FontSize="11" FontStyle="Italic"
                                                                           Foreground="{StaticResource SectionLabelBrush}" Padding="54,8,14,4" TextWrapping="Wrap" />
                                                                <ItemsControl ItemsSource="{Binding Browsers}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border BorderBrush="{StaticResource RowHoverBrush}" BorderThickness="0,0,0,0.5" Padding="54,6,14,6">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <ToggleButton Grid.Column="0" Style="{StaticResource BoxCheck}" VerticalAlignment="Center"
                                                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                                                                    <TextBlock Grid.Column="2" Text="{Binding DisplaySize}" FontSize="11" Foreground="{StaticResource TextFaintBrush}"
                                                                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                            <!-- Files (other categories) -->
                                                            <StackPanel Visibility="{Binding ShowFiles, Converter={StaticResource BoolToVis}}">
                                                            <ItemsControl ItemsSource="{Binding Files}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border BorderBrush="{StaticResource RowHoverBrush}" BorderThickness="0,0,0,0.5" Padding="54,5,14,5">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                                           Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" ToolTip="{Binding FullPath}" FontSize="11"
                                                                                           Foreground="{StaticResource TextFaintBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                                <TextBlock Grid.Column="2" Text="{Binding DisplaySize}" FontSize="11"
                                                                                           Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <TextBlock Text="{Binding MoreText}" FontSize="11" FontStyle="Italic" Foreground="{StaticResource StatLabelBrush}"
                                                                       Padding="54,5,14,6" Visibility="{Binding HasMore, Converter={StaticResource BoolToVis}}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0" Padding="14,12">
                            <Grid>
                                <Button Style="{StaticResource AccentButton}" Padding="9"
                                        Command="{Binding CleanAllCommand}"
                                        Content="{Binding CleanButtonText}"
                                        Visibility="{Binding NotCleanDone, Converter={StaticResource BoolToVis}}" />
                                <Border CornerRadius="7" Padding="9" Background="{StaticResource SuccessSoftBrush}"
                                        BorderBrush="{StaticResource SuccessBorderBrush}" BorderThickness="0.5"
                                        Visibility="{Binding CleanDone, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource SuccessBrush}" />
                                        <TextBlock Text="{Binding [dash.cleaned], Source={StaticResource Loc}}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource SuccessBrush}" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Right column ===== -->
        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource Panel}" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding [dash.diskUsage], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" Margin="0,0,0,14" />
                    <TextBlock Text="{Binding [disk.notAnalyzed], Source={StaticResource Loc}}"
                               Visibility="{Binding DiskNotAnalyzed, Converter={StaticResource BoolToVis}}"
                               FontSize="11" Foreground="{StaticResource SectionLabelBrush}" TextWrapping="Wrap"
                               LineHeight="18" Margin="0,0,0,10" />
                    <ItemsControl ItemsSource="{Binding DiskSegments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" />
                                        <TextBlock Text="{Binding Percent, StringFormat={}{0}%}" HorizontalAlignment="Right"
                                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource MiniBar}"
                                                 Value="{Binding Percent, Mode=OneWay}"
                                                 Foreground="{Binding ColorHex, Converter={StaticResource StringToBrush}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0.5,0,0" Margin="0,4,0,0" Padding="0,12,0,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding [dash.occupied], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" />
                                <TextBlock Text="{Binding DiskUsedText}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="{Binding [dash.freeUp], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding DiskFreeText}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource SuccessBrush}" Margin="0,2,0,0" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding [dash.lastClean], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" Margin="0,0,0,10" />
                    <TextBlock Text="{Binding [dash.never], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource SectionLabelBrush}" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding [dash.recommend], Source={StaticResource Loc}}"
                               FontSize="11" Foreground="{StaticResource SectionLabelBrush}" TextWrapping="Wrap" LineHeight="18" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
