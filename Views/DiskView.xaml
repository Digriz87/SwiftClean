<UserControl x:Class="SwiftClean.Views.DiskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SwiftClean.ViewModels"
             xmlns:helpers="clr-namespace:SwiftClean.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             d:DesignWidth="860" d:DesignHeight="540"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="Legend" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,0,16,0" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="264" />
        </Grid.ColumnDefinitions>

        <!-- Left -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding DriveLabelText}" Style="{StaticResource PanelTitle}" />
                            <TextBlock Text="{Binding DiskOccupiedLine}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right">
                            <TextBlock Text="{Binding DiskFreeText}" FontSize="22" FontWeight="Medium" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding DiskFreeOfLine}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                    <!-- used / free bar -->
                    <ProgressBar Style="{StaticResource MiniBar}" Height="8" Margin="0,0,0,12"
                                 Foreground="{StaticResource AccentBrush}" Value="{Binding UsedPercent, Mode=OneWay}" />
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal"><Border Width="10" Height="10" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" /><TextBlock Text="{Binding UsedPercentText}" Style="{StaticResource Legend}" /></StackPanel>
                        <StackPanel Orientation="Horizontal"><Border Width="10" Height="10" CornerRadius="2" Background="{StaticResource TrackBrush}" VerticalAlignment="Center" /><TextBlock Text="{Binding FreePercentText}" Style="{StaticResource Legend}" /></StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- usage map: finviz-style application treemap (tile = app, area ∝ size, color = recency) -->
            <Border Grid.Row="1" Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{Binding [disk.usageMap], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AppMapCaption}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{StaticResource TextFaintBrush}" />
                    </Grid>

                    <!-- treemap -->
                    <Border Grid.Row="1" MinHeight="240" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding DiskTiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <helpers:TreemapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="helpers:TreemapPanel.Weight" Value="{Binding Weight}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BgHex, Converter={StaticResource StringToBrush}}"
                                                BorderBrush="{Binding BorderHex, Converter={StaticResource StringToBrush}}"
                                                BorderThickness="0.5" CornerRadius="3" Margin="1.5" Padding="6,5"
                                                ClipToBounds="True" ToolTip="{Binding ToolTipText}">
                                            <StackPanel VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Medium"
                                                           Foreground="{Binding TextHex, Converter={StaticResource StringToBrush}}"
                                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                                <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="{StaticResource SectionLabelBrush}"
                                                           Margin="0,1,0,0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding [disk.noApps], Source={StaticResource Loc}}"
                                       Visibility="{Binding NoAppTiles, Converter={StaticResource BoolToVis}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{StaticResource SectionLabelBrush}" />
                        </Grid>
                    </Border>

                    <!-- recency legend -->
                    <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#5ed99a" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [disk.legendRecent], Source={StaticResource Loc}}" Style="{StaticResource Legend}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#e0a85c" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [disk.legendMonths], Source={StaticResource Loc}}" Style="{StaticResource Legend}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#ec6b6b" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [disk.legendStale], Source={StaticResource Loc}}" Style="{StaticResource Legend}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="10" Height="10" CornerRadius="2" Background="#8a8a94" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [disk.legendUnknown], Source={StaticResource Loc}}" Style="{StaticResource Legend}" />
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: large folders -->
        <Border Grid.Column="1" Style="{StaticResource Panel}" VerticalAlignment="Top">
            <StackPanel>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="14,12">
                    <TextBlock Text="{Binding [disk.largeFolders], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" />
                </Border>
                <ItemsControl ItemsSource="{Binding DiskFolders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Cursor="Hand" HorizontalContentAlignment="Stretch" ToolTip="{Binding [disk.openFolder], Source={StaticResource Loc}}"
                                    Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Row" Background="Transparent" BorderBrush="{StaticResource DividerBrush}"
                                                BorderThickness="0,0,0,0.5" Padding="14,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                           Foreground="{Binding IconColorHex, Converter={StaticResource StringToBrush}}" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                                                    <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{StaticResource SectionLabelBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Size}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" VerticalAlignment="Center" />
                                                <TextBlock x:Name="Open" Grid.Column="3" Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Row" Property="Background" Value="{StaticResource RowHoverBrush}" />
                                                <Setter TargetName="Open" Property="Foreground" Value="{StaticResource AccentLightBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
