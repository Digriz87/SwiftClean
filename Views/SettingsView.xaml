<UserControl x:Class="SwiftClean.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SwiftClean.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             d:DesignWidth="600" d:DesignHeight="640"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <!-- Selectable chip (accent when its bound Tag is true) -->
        <Style x:Key="Chip" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="7" Padding="18,7" Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
        <!-- Language -->
        <Border Style="{StaticResource Panel}" Padding="16">
            <StackPanel>
                <TextBlock Text="{Binding [set.language], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <Button Cursor="Hand" Command="{Binding ChangeLanguageCommand}" CommandParameter="ru">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Padding="18,7" Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                                    <TextBlock x:Name="T" Text="Русский" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextFaintBrush}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsRussian, Source={StaticResource Loc}}" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="T" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Cursor="Hand" Margin="6,0,0,0" Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="7" Padding="18,7" Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5">
                                    <TextBlock x:Name="T" Text="English" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextFaintBrush}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsEnglish, Source={StaticResource Loc}}" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="T" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Theme -->
        <Border Style="{StaticResource Panel}" Padding="16" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding [set.theme], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <Border CornerRadius="7" Background="{StaticResource AccentBrush}" Padding="18,7">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEC46;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" />
                            <TextBlock Text="{Binding [set.dark], Source={StaticResource Loc}}" FontSize="13" FontWeight="Medium" Foreground="White" Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="7" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5" Padding="18,7" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource SectionLabelBrush}" />
                            <TextBlock Text="{Binding [set.light], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource SectionLabelBrush}" Margin="6,0,0,0" />
                            <Border CornerRadius="4" Background="{StaticResource BadgeBgBrush}" Padding="5,1" Margin="6,0,0,0">
                                <TextBlock Text="v1.2" FontSize="10" Foreground="{StaticResource StatLabelBrush}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- General -->
        <Border Style="{StaticResource Panel}" Margin="0,12,0,0">
            <StackPanel>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="14,12">
                    <TextBlock Text="{Binding [set.general], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                </Border>
                <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,0.5" Padding="14,13">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding [set.notif], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="{Binding [set.notifSub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleButton Style="{StaticResource PillToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>
                <Border Padding="14,13">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding [set.autostart], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="{Binding [set.autostartSub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleButton Style="{StaticResource PillToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding AutostartEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- About -->
        <Border Style="{StaticResource Panel}" Padding="16" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding [set.about], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" Margin="0,0,0,14" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource LogoGradientBrush}">
                        <TextBlock Text="&#x2726;" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="SwiftClean" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                        <TextBlock Text="{Binding [set.version], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{Binding [set.aboutText], Source={StaticResource Loc}}"
                           FontSize="12" Foreground="{StaticResource StatLabelBrush}" TextWrapping="Wrap" LineHeight="20" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
