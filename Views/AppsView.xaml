<UserControl x:Class="SwiftClean.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SwiftClean.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             d:DesignWidth="860" d:DesignHeight="540"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <!-- Clickable, sortable column header -->
        <Style x:Key="SortHeader" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SectionLabelBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="248" />
        </Grid.ColumnDefinitions>

        <!-- ===== Left: search + table ===== -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search -->
            <Border Grid.Row="0" Style="{StaticResource Panel}" CornerRadius="8" Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource TextFaintBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding AppsSearch, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" Padding="8,10" FontSize="13"
                             Foreground="{StaticResource TextBrightBrush}" CaretBrush="{StaticResource TextBrightBrush}"
                             VerticalContentAlignment="Center" />
                </Grid>
            </Border>

            <!-- Table -->
            <Border Grid.Row="1" Style="{StaticResource Panel}" Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource SortHeader}" Command="{Binding SortAppsCommand}" CommandParameter="name">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [apps.name], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                                    <TextBlock Text="{Binding SortArrow}" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="{StaticResource AccentLightBrush}"
                                               Margin="4,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSortName, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Style="{StaticResource SortHeader}" Command="{Binding SortAppsCommand}" CommandParameter="size">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [apps.size], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                                    <TextBlock Text="{Binding SortArrow}" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="{StaticResource AccentLightBrush}"
                                               Margin="4,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSortSize, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Style="{StaticResource SortHeader}" Command="{Binding SortAppsCommand}" CommandParameter="date">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [apps.installedCol], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                                    <TextBlock Text="{Binding SortArrow}" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="{StaticResource AccentLightBrush}"
                                               Margin="4,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSortDate, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3" Style="{StaticResource SortHeader}" Command="{Binding SortAppsCommand}" CommandParameter="used">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [apps.usedCol], Source={StaticResource Loc}}" Style="{StaticResource ColLabel}" />
                                    <TextBlock Text="{Binding SortArrow}" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="{StaticResource AccentLightBrush}"
                                               Margin="4,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSortUsed, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding FilteredApps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,0.5" Padding="14,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Publisher}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Size}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Date}" FontSize="12" Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{Binding LastUsed}" FontSize="12" Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" />
                                            <Button Grid.Column="4" Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.UninstallAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock x:Name="T" Text="{Binding [apps.remove], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource ErrorBrush}" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="T" Property="Foreground" Value="#ff7070" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Right: storage stats ===== -->
        <Border Grid.Column="1" Style="{StaticResource Panel}" Padding="16" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{Binding [apps.storage], Source={StaticResource Loc}}" Style="{StaticResource PanelTitle}" Margin="0,0,0,16" />

                <TextBlock Text="{Binding [apps.installed], Source={StaticResource Loc}}" Style="{StaticResource StatLabelText}" />
                <TextBlock Text="{Binding AppsCountText}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" Margin="0,2,0,14" />

                <TextBlock Text="{Binding [apps.occupy], Source={StaticResource Loc}}" Style="{StaticResource StatLabelText}" />
                <TextBlock Text="{Binding AppsTotalSize}" FontSize="22" FontWeight="Medium" Foreground="{StaticResource WarningBrush}" Margin="0,2,0,0" />

                <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0.5,0,0" Margin="0,14,0,0" Padding="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding [apps.freeOnC], Source={StaticResource Loc}}" Style="{StaticResource StatLabelText}" />
                        <TextBlock Text="{Binding FreeSpaceText}" FontSize="22" FontWeight="Medium" Foreground="{StaticResource SuccessBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource GhostButton}" Content="{Binding [apps.refresh], Source={StaticResource Loc}}" Padding="0,9" Margin="0,16,0,0"
                        Command="{Binding RefreshAppsCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
