<UserControl x:Class="SwiftClean.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SwiftClean.ViewModels"
             xmlns:models="clr-namespace:SwiftClean.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             d:DesignWidth="820" d:DesignHeight="560"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <!-- Shared 6-column grid for header + rows -->
        <GridLength x:Key="ColType">110</GridLength>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Top bar: dev notice + stats + actions ===== -->
        <StackPanel Grid.Row="0">
            <!-- Under-development notice -->
            <Border Background="{StaticResource WarnSoftBrush}" BorderBrush="{StaticResource WarningBrush}" BorderThickness="0.5"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding [drv.beta], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource WarningBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Grid>
            <StackPanel Orientation="Horizontal">
                <!-- Outdated -->
                <Border Background="{StaticResource ErrorSoftBrush}" BorderBrush="{StaticResource ErrorBorderBrush}" BorderThickness="0.5"
                        CornerRadius="8" Padding="14,7" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DriverOutdatedCount}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource ErrorBrush}" Margin="6,0,0,0" />
                        <TextBlock Text="{Binding [drv.outdatedLabel], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" Margin="5,0,0,0" />
                    </StackPanel>
                </Border>
                <!-- Up to date -->
                <Border Background="{StaticResource SuccessSoftBrush}" BorderBrush="{StaticResource SuccessBorderBrush}" BorderThickness="0.5"
                        CornerRadius="8" Padding="14,7" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DriverUptodateCount}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource SuccessBrush}" Margin="6,0,0,0" />
                        <TextBlock Text="{Binding [drv.uptodateLabel], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" Margin="5,0,0,0" />
                    </StackPanel>
                </Border>
                <!-- Total -->
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5"
                        CornerRadius="8" Padding="14,7">
                    <TextBlock Text="{Binding DriverTotalText}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Scan -->
                <Button Style="{StaticResource GhostButton}" Command="{Binding ScanDriversCommand}" Padding="16,7" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [drv.scan], Source={StaticResource Loc}}" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <!-- Update all -->
                <Button Style="{StaticResource AccentButton}" Command="{Binding UpdateAllDriversCommand}" Padding="18,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding [drv.updateAll], Source={StaticResource Loc}}" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
            </Grid>
        </StackPanel>

        <!-- ===== Progress: device enumeration, then Windows Update check ===== -->
        <Border Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource Panel}" Padding="16,14"
                Visibility="{Binding DriverBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DriverBusyText}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        <!-- Spinner during the Windows Update phase (no percentage available) -->
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource AccentBrush}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                   Visibility="{Binding WuSearching, Converter={StaticResource BoolToVis}}">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="WuSpinnerRot" Angle="0" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WuSpinnerRot" Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                    </StackPanel>
                    <!-- Percentage only during enumeration -->
                    <TextBlock Text="{Binding DriverScanProgress, StringFormat={}{0}%}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"
                               Visibility="{Binding DriverScanning, Converter={StaticResource BoolToVis}}" />
                </Grid>
                <ProgressBar Style="{StaticResource MiniBar}" Height="4" Minimum="0" Maximum="100"
                             Value="{Binding DriverScanProgress, Mode=OneWay}" Foreground="{StaticResource ScanFillBrush}" Margin="0,0,0,8"
                             Visibility="{Binding DriverScanning, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding DriverCheckingText}" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource SectionLabelBrush}"
                           Visibility="{Binding DriverScanning, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>

        <!-- ===== Driver table ===== -->
        <Border Grid.Row="2" Margin="0,14,0,0" Style="{StaticResource Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5"
                        Padding="14,9" CornerRadius="10,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource ColLabel}" Text="{Binding [drv.colDevice], Source={StaticResource Loc}}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource ColLabel}" Text="{Binding [drv.colType], Source={StaticResource Loc}}" />
                        <TextBlock Grid.Column="2" Style="{StaticResource ColLabel}" Text="{Binding [drv.colVersion], Source={StaticResource Loc}}" />
                        <TextBlock Grid.Column="3" Style="{StaticResource ColLabel}" Text="{Binding [drv.colDate], Source={StaticResource Loc}}" />
                        <TextBlock Grid.Column="4" Style="{StaticResource ColLabel}" Text="{Binding [drv.colStatus], Source={StaticResource Loc}}" />
                        <TextBlock Grid.Column="5" />
                    </Grid>
                </Border>

                <!-- Rows -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Drivers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DriverInfo}">
                                <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,0.5" Padding="14,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Device name + manufacturer -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding DeviceName}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding DeviceName}" />
                                            <TextBlock Text="{Binding ManufacturerText}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,2,0,0" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding DeviceTypeLabel}" FontSize="11" Foreground="{StaticResource TextFaintBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding VersionText}" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource StatLabelBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding DateText}" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" />

                                        <!-- Status badge — neutral "not checked" until a real WU search runs -->
                                        <Border x:Name="StatusPill" Grid.Column="4" CornerRadius="5" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{StaticResource TrackBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5">
                                            <TextBlock x:Name="StatusText" Text="{Binding StatusLabel}" FontSize="11" Foreground="{StaticResource TextFaintBrush}" />
                                        </Border>

                                        <!-- Action cell: Update button (when WU found an update) ⇄ installing spinner -->
                                        <Grid Grid.Column="5" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <!-- Update — downloads + installs this driver via the Windows Update API -->
                                            <Button x:Name="UpdateBtn" Cursor="Hand" Visibility="Collapsed"
                                                    Command="{Binding DataContext.UpdateDriverCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="{StaticResource AccentBrush}" CornerRadius="6" Padding="10,5">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="White" VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding [drv.update], Source={StaticResource Loc}}" FontSize="11" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Installing — rotating spinner while the driver downloads/installs -->
                                            <StackPanel x:Name="InstallingBox" Orientation="Horizontal" Visibility="Collapsed">
                                                <TextBlock x:Name="Spinner" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{StaticResource AccentLightBrush}" VerticalAlignment="Center"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="SpinT" Angle="0" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <TextBlock Text="{Binding [drv.installing], Source={StaticResource Loc}}" FontSize="11"
                                                           Foreground="{StaticResource AccentLightBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- WU found an update for this device → amber + Update button -->
                                    <DataTrigger Binding="{Binding IsOutdated}" Value="True">
                                        <Setter TargetName="UpdateBtn"  Property="Visibility" Value="Visible" />
                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource WarningBrush}" />
                                        <Setter TargetName="StatusPill" Property="Background"  Value="{StaticResource WarnSoftBrush}" />
                                    </DataTrigger>
                                    <!-- WU checked, no update → green, no button -->
                                    <DataTrigger Binding="{Binding IsUpToDate}" Value="True">
                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                        <Setter TargetName="StatusPill" Property="Background"  Value="{StaticResource SuccessSoftBrush}" />
                                        <Setter TargetName="StatusPill" Property="BorderBrush" Value="{StaticResource SuccessBorderBrush}" />
                                    </DataTrigger>
                                    <!-- Installing → hide the button, show the spinning indicator (last, so it wins) -->
                                    <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                        <Setter TargetName="UpdateBtn"     Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="InstallingBox" Property="Visibility" Value="Visible" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SpinSB">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SpinT" Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SpinSB" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding DriverShowEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="{StaticResource BorderLightBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding [drv.empty1], Source={StaticResource Loc}}" FontSize="13" Foreground="{StaticResource StatLabelBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                    <TextBlock Text="{Binding [drv.empty2], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0"
                        Padding="14,10" CornerRadius="0,0,10,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [drv.footer], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding [drv.scanComplete], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Visibility="{Binding DriverCheckComplete, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
