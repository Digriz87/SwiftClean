<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:SwiftClean.Installer.Helpers">

    <!-- ════════ Converters ════════ -->
    <h:BoolToVisibilityConverter x:Key="BoolToVis" />
    <h:StringToGeometryConverter x:Key="StrToGeom" />
    <h:LogKindToBrushConverter x:Key="LogBrush" />

    <!-- ════════ Palette (from SwiftClean Installer.dc.html) ════════ -->
    <SolidColorBrush x:Key="DesktopBackdrop" Color="#0a0a0c" />
    <SolidColorBrush x:Key="WindowBrush" Color="#111114" />
    <SolidColorBrush x:Key="TitleBarBrush" Color="#0d0d10" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#0d0d10" />
    <SolidColorBrush x:Key="NavBarBrush" Color="#0f0f11" />
    <SolidColorBrush x:Key="InsetBrush" Color="#0f0f11" />
    <SolidColorBrush x:Key="LogBgBrush" Color="#0a0a0c" />
    <SolidColorBrush x:Key="CardBrush" Color="#1a1a1f" />
    <SolidColorBrush x:Key="ChipBrush" Color="#141418" />
    <SolidColorBrush x:Key="ToggleOffBrush" Color="#1e1e28" />

    <SolidColorBrush x:Key="BorderBrush" Color="#1e1e24" />
    <SolidColorBrush x:Key="BorderDimBrush" Color="#1a1a1e" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#2a2a35" />

    <SolidColorBrush x:Key="AccentBrush" Color="#5b4fff" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="#8b6fff" />
    <SolidColorBrush x:Key="BlueBrush" Color="#5b7fff" />
    <SolidColorBrush x:Key="GreenBrush" Color="#3dd68c" />
    <SolidColorBrush x:Key="AmberBrush" Color="#d4924a" />
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#c42b2b" />

    <SolidColorBrush x:Key="TextBrightBrush" Color="#e8e8ec" />
    <SolidColorBrush x:Key="TextBodyBrush" Color="#c8c8d4" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#b8b8c8" />
    <SolidColorBrush x:Key="TextSoftBrush" Color="#8b8b9a" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="#6b6b78" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#45454f" />
    <SolidColorBrush x:Key="TextFaintestBrush" Color="#38383f" />

    <!-- Soft icon-tile backgrounds -->
    <SolidColorBrush x:Key="TilePurpleBrush" Color="#1a1630" />
    <SolidColorBrush x:Key="TileBlueBrush" Color="#101828" />
    <SolidColorBrush x:Key="TileAmberBrush" Color="#1f1a10" />
    <SolidColorBrush x:Key="TileGreenBrush" Color="#0f1f17" />

    <!-- Gradients -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5b4fff" Offset="0" />
        <GradientStop Color="#7c6fff" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BarGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5b4fff" Offset="0" />
        <GradientStop Color="#8b6fff" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RingGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5b4fff" Offset="0" />
        <GradientStop Color="#8b6fff" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SuccessTileGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1a3a1a" Offset="0" />
        <GradientStop Color="#0f2a0f" Offset="1" />
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="DesktopGlow" GradientOrigin="0.3,0.4" Center="0.3,0.4" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#1a1040" Offset="0" />
        <GradientStop Color="#0a0a0c" Offset="0.7" />
    </RadialGradientBrush>

    <!-- ════════ App logo (vector port of SwiftClean_Icon.svg) ════════ -->
    <DrawingImage x:Key="AppLogo">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Rounded gradient tile -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3d2fff" Offset="0" />
                            <GradientStop Color="#5b4fff" Offset="0.6" />
                            <GradientStop Color="#7c5cfc" Offset="1" />
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,512,512" RadiusX="114" RadiusY="114" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Clean arc (open ring) -->
                <GeometryDrawing Geometry="M256,148 A108,108 0 1 1 178,310">
                    <GeometryDrawing.Pen>
                        <Pen Brush="White" Thickness="26" StartLineCap="Round" EndLineCap="Round" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
                <!-- Arrow head -->
                <GeometryDrawing Brush="White" Geometry="M160,330 L142,296 196,298 Z" />
                <!-- Big sparkle (translate 336,154) -->
                <GeometryDrawing Brush="White"
                    Geometry="M336,132 C336,148 330,154 314,154 C330,154 336,160 336,176 C336,160 342,154 358,154 C342,154 336,148 336,132 Z" />
                <!-- Small sparkle (translate 176,342) -->
                <GeometryDrawing Brush="#CCFFFFFF"
                    Geometry="M176,329 C176,338 172,342 163,342 C172,342 176,346 176,355 C176,346 180,342 189,342 C180,342 176,338 176,329 Z" />
                <!-- Dots -->
                <GeometryDrawing Brush="#8CFFFFFF">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="194,178" RadiusX="7" RadiusY="7" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#66FFFFFF">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="358,296" RadiusX="5" RadiusY="5" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ════════ Thin scrollbar (implicit, applied app-wide) ════════ -->
    <Style TargetType="{x:Type Thumb}" x:Key="ScrollThumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="#2a2a35" CornerRadius="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ Checkbox tile (16×16 accent square with check) ════════ -->
    <Style x:Key="CheckSquare" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="box" Width="17" Height="17" CornerRadius="4"
                            Background="{StaticResource ToggleOffBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                        <TextBlock x:Name="chk" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="White" Visibility="Collapsed"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="chk" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
