<Window x:Class="SwiftClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SwiftClean"
        xmlns:vm="clr-namespace:SwiftClean.ViewModels"
        xmlns:views="clr-namespace:SwiftClean.Views"
        mc:Ignorable="d"
        Title="SwiftClean"
        Icon="pack://application:,,,/Resources/AppIcon.ico"
        Height="700" Width="1180"
        MinHeight="560" MinWidth="900"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        BorderThickness="0" BorderBrush="Transparent"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrightBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" ResizeBorderThickness="6"
                      CornerRadius="0" NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Window chrome buttons -->
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RowHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Scan modal progress bar -->
        <Style x:Key="ScanBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource ScanFillBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track" Background="{StaticResource TrackBrush}" CornerRadius="2" />
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5" Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===================== SIDEBAR ===================== -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0.5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="16,18,16,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="7" Background="{StaticResource LogoGradientBrush}">
                                <TextBlock Text="&#x2726;" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="SwiftClean" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                                <TextBlock Text="v1.0.0" FontSize="10" Foreground="{StaticResource SectionLabelBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Nav -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NavigationView}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource NavItem}"
                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Medium"
                                                       Foreground="{StaticResource SectionLabelBrush}" Margin="14,16,14,4" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Support -->
                    <Button Grid.Row="2" Margin="10,0,10,12" Cursor="Hand" Command="{Binding SupportCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="8" Padding="12,10"
                                        Background="{StaticResource SupportBrush}" BorderBrush="{StaticResource SupportBorderBrush}" BorderThickness="0.5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource AccentLightBrush}" VerticalAlignment="Center" />
                                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding [support.title], Source={StaticResource Loc}}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource AccentLightBrush}" />
                                            <TextBlock Text="{Binding [support.sub], Source={StaticResource Loc}}" FontSize="10" Foreground="{StaticResource StatLabelBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#201c40" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ===================== MAIN ===================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="28" />
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5"
                        MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock Text="{Binding PageTitle}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                            <TextBlock Text="{Binding DateStr}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" />
                        </StackPanel>

                        <!-- Scan button -->
                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Command="{Binding ScanCommand}" Cursor="Hand"
                                    Visibility="{Binding NotScanning, Converter={StaticResource BoolToVis}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{StaticResource AccentBrush}" CornerRadius="7" Padding="16,7">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" />
                                                <TextBlock Text="{Binding [btn.scan], Source={StaticResource Loc}}" FontSize="13" FontWeight="Medium" Foreground="White" Margin="6,0,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Border Background="#3a30b8" CornerRadius="7" Padding="16,7"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#8CFFFFFF" RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform><RotateTransform /></TextBlock.RenderTransform>
                                        <TextBlock.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </TextBlock.Triggers>
                                    </TextBlock>
                                    <TextBlock Text="{Binding [btn.scanning], Source={StaticResource Loc}}" FontSize="13" FontWeight="Medium" Foreground="#8CFFFFFF" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Window controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource ChromeButtonStyle}" Content="&#xE921;" ToolTip="Minimize" Click="MinimizeButton_Click" />
                            <Button x:Name="MaxButton" Style="{StaticResource ChromeButtonStyle}" Content="&#xE922;" ToolTip="Maximize" Click="MaximizeButton_Click" />
                            <Button Style="{StaticResource CloseButtonStyle}" Content="&#xE8BB;" ToolTip="Close" Click="CloseButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" x:Name="ContentScroller" VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=ContentScroller}">
                        <views:DashboardView Visibility="{Binding IsDashboard, Converter={StaticResource BoolToVis}}"
                                             MaxHeight="{Binding ViewportHeight, ElementName=ContentScroller}" VerticalAlignment="Top" />
                        <views:CleaningView  Visibility="{Binding IsCleaning,  Converter={StaticResource BoolToVis}}" />
                        <views:RegistryView  Visibility="{Binding IsRegistry,  Converter={StaticResource BoolToVis}}"
                                             MaxHeight="{Binding ViewportHeight, ElementName=ContentScroller}" VerticalAlignment="Top" />
                        <views:StartupView   Visibility="{Binding IsStartup,   Converter={StaticResource BoolToVis}}" />
                        <views:AppsView      Visibility="{Binding IsApps,      Converter={StaticResource BoolToVis}}"
                                             MaxHeight="{Binding ViewportHeight, ElementName=ContentScroller}" VerticalAlignment="Top" />
                        <views:DiskView      Visibility="{Binding IsDisk,      Converter={StaticResource BoolToVis}}" />
                        <views:DriversView   Visibility="{Binding IsDrivers,   Converter={StaticResource BoolToVis}}"
                                             MaxHeight="{Binding ViewportHeight, ElementName=ContentScroller}" VerticalAlignment="Top" />
                        <views:SchedulerView Visibility="{Binding IsScheduler, Converter={StaticResource BoolToVis}}" />
                        <views:SettingsView  Visibility="{Binding IsSettings,  Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </ScrollViewer>

                <!-- Status bar -->
                <Border Grid.Row="2" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0">
                    <Grid Margin="14,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding [status.ready], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="5,0,0,0" />
                            <Border Width="0.5" Height="12" Background="{StaticResource BorderBrush}" Margin="14,0" />
                            <TextBlock Text="{Binding [status.os], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="CPU" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" />
                            <TextBlock Text="{Binding CpuVal}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="4,0,16,0" />
                            <TextBlock Text="RAM" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" />
                            <TextBlock Text="{Binding RamVal}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="4,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================== SCAN MODAL ===================== -->
            <Border Grid.ColumnSpan="2" Background="{StaticResource ScanOverlayBrush}"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <Border Width="440" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5"
                        CornerRadius="12" Padding="32,28" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform><RotateTransform /></TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock Text="{Binding [scan.title], Source={StaticResource Loc}}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                                <TextBlock Text="{Binding [scan.sub], Source={StaticResource Loc}}" FontSize="11" Foreground="{StaticResource SectionLabelBrush}" Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding ScanProgress, StringFormat={}{0}%}" FontSize="18" FontWeight="Medium"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </Grid>

                        <ProgressBar Style="{StaticResource ScanBar}" Value="{Binding ScanProgress, Mode=OneWay}" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding ScanFile}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource SectionLabelBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,20" />

                        <ItemsControl ItemsSource="{Binding ScanStages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                        <Grid Width="13" Height="13" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource SuccessBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock.RenderTransform><RotateTransform /></TextBlock.RenderTransform>
                                                <TextBlock.Triggers>
                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </TextBlock.Triggers>
                                            </TextBlock>
                                            <Border Width="13" Height="13" CornerRadius="6.5" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1.5"
                                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Name}" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource SectionLabelBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource StatLabelBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ===================== CONFIRM DIALOG ===================== -->
            <Border Grid.ColumnSpan="2" Background="{StaticResource ScanOverlayBrush}"
                    Visibility="{Binding IsDialogVisible, Converter={StaticResource BoolToVis}}">
                <Border Width="430" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5"
                        CornerRadius="12" Padding="28,24" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding DialogTitle}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                        <TextBlock Text="{Binding DialogMessage}" FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" LineHeight="20" Margin="0,12,0,0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                            <Button Style="{StaticResource GhostButton}" Content="{Binding DialogCancelText}" Padding="18,9"
                                    Command="{Binding DialogCancelCommand}" />
                            <Button Style="{StaticResource AccentButton}" Content="{Binding DialogConfirmText}" Padding="18,9"
                                    Margin="8,0,0,0" Command="{Binding DialogConfirmCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ===================== SUPPORT POPUP ===================== -->
            <Border Grid.ColumnSpan="2" Background="#D90A0A0C"
                    MouseLeftButtonDown="SupportOverlay_Click"
                    Visibility="{Binding IsSupportVisible, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSupportVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Border Width="460" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5"
                        CornerRadius="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                        MouseLeftButtonDown="SupportCard_Click">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="30" Direction="270" Opacity="0.7" />
                    </Border.Effect>
                    <Grid>
                        <StackPanel Margin="32">
                            <!-- Header: avatar + name -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Width="52" Height="52" CornerRadius="26" Background="{StaticResource LogoGradientBrush}">
                                    <TextBlock Text="V" Foreground="White" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock Text="{Binding [support.name], Source={StaticResource Loc}}" FontSize="16" FontWeight="Medium" Foreground="{StaticResource TextBrightBrush}" />
                                    <TextBlock Text="{Binding [support.role], Source={StaticResource Loc}}" FontSize="12" Foreground="{StaticResource TextFaintBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Story -->
                            <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Margin="0,0,0,12">
                                <Run Text="{Binding [story.p1a], Source={StaticResource Loc}, Mode=OneWay}" Foreground="#8b8b9a" />
                                <Run Text="{Binding [story.p1b], Source={StaticResource Loc}, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}" FontWeight="Medium" />
                                <Run Text="{Binding [story.p1c], Source={StaticResource Loc}, Mode=OneWay}" Foreground="#8b8b9a" />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Margin="0,0,0,12">
                                <Run Text="{Binding [story.p2a], Source={StaticResource Loc}, Mode=OneWay}" Foreground="#8b8b9a" />
                                <Run Text="{Binding [story.p2b], Source={StaticResource Loc}, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}" FontWeight="Medium" />
                                <Run Text="{Binding [story.p2c], Source={StaticResource Loc}, Mode=OneWay}" Foreground="#8b8b9a" />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13">
                                <Run Text="{Binding [story.p3a], Source={StaticResource Loc}, Mode=OneWay}" Foreground="#8b8b9a" />
                                <Run Text="{Binding [story.p3b], Source={StaticResource Loc}, Mode=OneWay}" Foreground="{StaticResource AccentLightBrush}" FontWeight="Medium" />
                                <Run Text="{Binding [story.p3c], Source={StaticResource Loc}, Mode=OneWay}" Foreground="#8b8b9a" />
                            </TextBlock>

                            <!-- CTA -->
                            <Button Style="{StaticResource AccentButton}" Padding="10" Margin="0,20,0,0"
                                    Content="{Binding [support.cta], Source={StaticResource Loc}}" Command="{Binding DonateCommand}" />

                            <!-- Thanks -->
                            <TextBlock Text="{Binding [support.thanks], Source={StaticResource Loc}}" FontSize="11"
                                       Foreground="{StaticResource SectionLabelBrush}" HorizontalAlignment="Center" Margin="0,14,0,0" />
                        </StackPanel>

                        <!-- Close -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="14" Width="28" Height="28"
                                Cursor="Hand" Command="{Binding CloseSupportCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" CornerRadius="7" Background="{StaticResource TrackBrush}">
                                        <TextBlock x:Name="X" Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{StaticResource TextFaintBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BorderLightBrush}" />
                                            <Setter TargetName="X" Property="Foreground" Value="{StaticResource TextBrightBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
